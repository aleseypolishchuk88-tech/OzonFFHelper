# Ключи Ozon Seller API
# Личный кабинет Ozon -> Настройки -> Seller API -> Сгенерировать ключ
# Скопируйте этот файл в .env и впишите свои значения. Файл .env в git не попадает.

OZON_CLIENT_ID=
OZON_API_KEY=

# (необязательно) Переопределение базового URL API — обычно менять не нужно.
# OZON_API_BASE=https://api-seller.ozon.ru
